{
  "enabled": true,
  "network": {
    "allowNetwork": true,
    "allowLocalBinding": true,
    "allowAllUnixSockets": false,
    "allowUnixSockets": [],
    "allowedDomains": [],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "/home"
    ],
    "allowRead": [
      ".",
      "/dev/null",
      "/tmp",
      "~/.cache",
      "~/.cargo",
      "~/.rustup",
      "~/.local/share/npm-global/lib/node_modules/@earendil-works",
      "~/.config/go",
      "~/.local/share/go",
      "~/.pi/agent/skills"
    ],
    "allowWrite": [
      ".",
      "/dev/null",
      "/tmp",
      "~/.cache",
      "~/.cargo",
      "~/.rustup",
      "~/.config/go",
      "~/.local/share/go"
    ],
    "denyWrite": []
  }
}
